syntax = "v1"

info (
	title:   "InterviewAPP Chat API"
	desc:    "Go面试官聊天API服务"
	author:  "wangdm"
	email:   "10086@163.com"
	version: "1.0"
)

type InterviewAPPChatReq {
	Message string `json:"message"`
	ChatId  string `json:"chatId"`
}

type ChatResponse {
	Content string `json:"content"`
	IsLast  bool   `json:"isLast"`
}

service chat {
	@doc "Go面试官聊天SSE流式接口"
	@handler Chat
	post /api/ai/inerview_app/chat/sse (InterviewAPPChatReq) returns (ChatResponse)
}

